<Window x:Class="DriveBender.UI.CreatePoolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create New Pool" Height="560" Width="640"
        MinHeight="480" MinWidth="560"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pool Name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Label Content="Pool Name:"/>
            <TextBox Name="PoolNameTextBox" Height="25"/>
        </StackPanel>

        <!-- Mount Point -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <Label Content="Mount Target (drive letter like X:\ or an empty directory; optional):"/>
            <TextBox Name="MountPointTextBox" Height="25"/>
        </StackPanel>

        <!-- Add-member row: any kind of member, not just local drives -->
        <GroupBox Grid.Row="2" Header="Add member" Margin="0,0,0,10">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Kind:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" Name="KindComboBox" Height="25" Margin="5,0"
                          SelectionChanged="KindComboBox_SelectionChanged"/>
                <Button Grid.Row="0" Grid.Column="2" Name="BrowseButton" Content="Browse…" Width="80" Height="25"
                        Click="BrowseButton_Click"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Location:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Name="MemberPathTextBox" Height="25" Margin="5,6,5,0"
                         ToolTip="Local folder, \\server\share\path, or a URI like sftp://user@host/path, s3://bucket/prefix, webdavs://host/dav"/>
                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="0,6,0,0">
                    <ComboBox Name="RoleComboBox" Width="90" Height="25" Margin="0,0,5,0"/>
                    <Button Name="AddMemberButton" Content="Add" Width="60" Height="25" Click="AddMemberButton_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Members list -->
        <GroupBox Grid.Row="3" Header="Members" Margin="0,0,0,10">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListView Grid.Row="0" Name="MembersListView" SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Kind" Width="110" DisplayMemberBinding="{Binding Kind}"/>
                            <GridViewColumn Header="Location" Width="330" DisplayMemberBinding="{Binding Location}"/>
                            <GridViewColumn Header="Role" Width="90" DisplayMemberBinding="{Binding Role}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Name="RemoveMemberButton" Content="Remove selected" Width="120" Height="25"
                            Click="RemoveMemberButton_Click"/>
                    <TextBlock Name="CredentialHintTextBlock" VerticalAlignment="Center" Margin="10,0,0,0"
                               Foreground="Gray"
                               Text="Remote members: store secrets first with 'dbmount credential set &lt;name&gt;', then use cred-ref:&lt;name&gt;."/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="OKButton" Content="Create" Width="90" Height="30"
                    Click="OKButton_Click" IsDefault="True" Margin="0,0,5,0"/>
            <Button Name="CancelButton" Content="Cancel" Width="90" Height="30"
                    Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
